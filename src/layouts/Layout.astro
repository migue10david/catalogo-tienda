---
interface Props {
  title?: string;
}

const { title = 'CATÁLOGO' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="CATÁLOGO - Tienda de productos únicos" />
  </head>
  <body class="min-h-screen bg-paper text-void font-body antialiased">
    <slot />
  </body>
</html>