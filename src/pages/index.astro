---
import "../styles/global.css";
import Layout from '../layouts/Layout.astro';
import { Catalog } from '../components/react/Catalog';
import { sanityClient } from 'sanity:client';

interface Product {
  _id: string;
  name: string;
  slug: string;
  price: number;
  description: string;
  imageUrl: string;
  images: string[];
  category: { title: string; slug: string } | null;
  brand: string | null;
  inStock: boolean;
}

interface CategoryData {
  _id: string;
  title: string;
  slug: string;
}

const PRODUCTS_QUERY = `*[_type == "product"] | order(_createdAt desc) {
  _id,
  name,
  "slug": slug.current,
  price,
  description,
  "imageUrl": images[0].asset->url,
  "images": images[].asset->url,
  "category": category->{title, "slug": slug.current},
  brand,
  inStock
}`;

const products = await sanityClient.fetch<Product[]>(PRODUCTS_QUERY);

const CATEGORIES_QUERY = `*[_type == "category"] | order(title asc) {
  _id,
  title,
  "slug": slug.current
}`;

const categories = await sanityClient.fetch<CategoryData[]>(CATEGORIES_QUERY);
---

