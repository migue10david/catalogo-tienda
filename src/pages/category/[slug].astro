---
import "../../styles/global.css";
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';

interface Product {
  _id: string;
  name: string;
  slug: string;
  price: number;
  description: string;
  imageUrl: string;
  category: { title: string; slug: string } | null;
  brand: string | null;
  inStock: boolean;
}

interface Category {
  _id: string;
  title: string;
  slug: string;
}

export async function getStaticPaths() {
  const categories = await sanityClient.fetch<Category[]>(`*[_type == "category"]{ "slug": slug.current }`);
  return categories.map(c => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;

const category = await sanityClient.fetch<Category>(`*[_type == "category" && slug.current == $slug][0]`, { slug });

const products = await sanityClient.fetch<Product[]>(`*[_type == "product" && category->slug.current == $slug] | order(_createdAt desc)`, { slug });

const allCategories = await sanityClient.fetch<Category[]>(`*[_type == "category"] | order(title asc)`);

const formatPrice = (price: number) => new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'USD', minimumFractionDigits: 0 }).format(price);
---

<Layout title={`${category.title} | Catálogo`}>
  <header class="sticky top-0 z-50 bg-[rgba(250,250,249,0.92)] backdrop-blur-md border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center justify-between gap-8">
      <a href="/" class="flex items-baseline gap-2 no-underline">
        <span class="font-display text-2xl tracking-tight">CATÁLOGO</span>
        <span class="text-xs text-stone-400 font-body">2025</span>
      </a>
      
      <nav class="flex items-center gap-2">
        <a href="/" class="text-sm text-stone-400 px-4 py-2 rounded-full transition-all duration-200 hover:text-stone-800 hover:bg-stone-100">Todos</a>
        {allCategories.map((cat) => (
          <a href={`/category/${cat.slug}`} class={`text-sm px-4 py-2 rounded-full transition-all duration-200 hover:text-stone-800 hover:bg-stone-100 ${cat.slug === slug ? 'text-stone-800 bg-stone-100' : 'text-stone-400'}`}>
            {cat.title}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <section class="py-12 border-b border-stone-200 mb-8">
      <nav class="flex items-center gap-2 text-sm text-stone-400 mb-4">
        <a href="/" class="hover:text-stone-800">Catálogo</a>
        <span>/</span>
        <span class="text-stone-800">{category.title}</span>
      </nav>
      
      <h1 class="font-display text-4xl sm:text-5xl text-stone-800">{category.title}</h1>
      <p class="text-stone-400 mt-3">{products.length} {products.length === 1 ? 'pieza' : 'piezas'}</p>
    </section>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {products.map((product, i) => (
        <a href={`/product/${product.slug}`} class="block" style={{ animationDelay: `${0.1 + i * 0.05}s` }}>
          <div class="relative aspect-[3/4] overflow-hidden bg-stone-100 mb-4">
            {product.imageUrl ? (
              <img src={product.imageUrl} alt={product.name} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 hover:scale-[1.03]" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-stone-400">Sin imagen</div>
            )}
            <div class="absolute inset-0 bg-stone-900/80 flex items-center justify-center opacity-0 transition-opacity duration-300 hover:opacity-100">
              <span class="text-white text-sm uppercase tracking-widest px-6 py-3 border border-white">Ver detalles</span>
            </div>
            {!product.inStock && <span class="absolute top-4 left-4 bg-stone-800 text-white text-xs uppercase tracking-wider px-3 py-1">Agotado</span>}
          </div>
          <div class="flex flex-col gap-2">
            {product.brand && <span class="text-xs text-stone-400">{product.brand}</span>}
            <h3 class="font-display text-xl text-stone-800">{product.name}</h3>
            <div class="flex items-center justify-between mt-1">
              <span class="font-body font-medium text-stone-800">{formatPrice(product.price)}</span>
              <span class={`text-xs px-2 py-1 rounded ${product.inStock ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700'}`}>
                {product.inStock ? 'Disponible' : 'Agotado'}
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {products.length === 0 && (
      <div class="py-24 text-center">
        <p class="font-display text-2xl text-stone-800">No hay productos en esta categoría</p>
        <p class="text-stone-400 mt-2">Pronto llegaran nuevas piezas</p>
      </div>
    )}
  </main>

  <footer class="border-t border-stone-200 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <div class="flex flex-col gap-1">
        <span class="font-display text-xl">CATÁLOGO</span>
        <span class="text-sm text-stone-400">Piezas seleccionadas con propósito</span>
      </div>
      <p class="text-sm text-stone-400">&copy; 2025 Catálogo.</p>
    </div>
  </footer>
</Layout>